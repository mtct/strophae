# Test environment (local dev, pytest, CI). Loaded by config/settings.py when
# DJANGO_ENV is unset or 'test'. These are throwaway dev credentials — they
# also provision the Docker database (compose.yaml reads this file), so the
# two sides always agree. Committed on purpose; real secrets belong only in
# .env.production (gitignored).
POSTGRES_DB=strophae
POSTGRES_USER=strophae
POSTGRES_PASSWORD=strophae
POSTGRES_HOST=127.0.0.1
# Host port published by compose.yaml (5432 is taken by other projects).
POSTGRES_PORT=5433
