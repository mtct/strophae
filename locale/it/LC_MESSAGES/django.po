#: templates/chat/settings.html:30 templates/chat/settings.html:33
msgid "Show"
msgstr "Mostra"

#: templates/chat/settings.html:32
msgid "Show or hide the key"
msgstr "Mostra o nascondi la chiave"

#: templates/chat/settings.html:35
msgid ""
"OpenRouter keys usually start with “sk-or-”. Double-check you pasted the "
"whole key."
msgstr "Le chiavi OpenRouter di solito iniziano con “sk-or-”. Controlla di aver incollato la chiave completa."
"Le chiavi OpenRouter di solito iniziano con “sk-or-”. Controlla di aver "
"incollato la chiave completa."

