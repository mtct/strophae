{
  "name": "strophae",
  "version": "0.1.0",
  "description": "Multi-persona chat: one prompt, many minds, streaming in parallel.",
  "private": true,
  "main": "dist/main/main.js",
  "author": "Matteo Costa",
  "license": "MIT",
  "scripts": {
    "build": "bun scripts/bundle.ts",
    "start": "bun run build && ELECTRON_RUN_AS_NODE= electron .",
    "check": "bun run build && ELECTRON_RUN_AS_NODE= electron . --check",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "dist": "bun run build && electron-builder"
  },
  "trustedDependencies": [
    "electron"
  ],
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "dompurify": "^3.4.12",
    "electron": "^43.1.1",
    "electron-builder": "^26.0.12",
    "mermaid": "^11.16.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "typescript": "^5.8.3",
    "word-extractor": "^1.0.4"
  }
}
